<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title or "Page" }}</title>

  {#       Body Text: Albert Sans Light Medium Bold Black #}
  {#     Header Text: Crimson Pro Light Medium Bold       #}
  {# Monospaced Text: JetBrains Mono Light                #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@300;500;700;900&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Crimson+Pro:wght@300,500,700&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300&display=swap">

  <link rel="stylesheet" href="{{ '/css/vendor/latex.css' | url }}">
  <link rel="stylesheet" href="{{ '/css/vendor/katex.min.css' | url }}">
  <link rel="stylesheet" href="{{ '/css/ledger-theme.css' | url }}">
</head>
<body>

  {# Navigation Sidebar Button #}
  <button
    id="sidebar-toggle"
    type="button"
    aria-expanded="false"
    aria-controls="sidebar"
    aria-label="Open Navigation">

    {# Navigation Sidebar Open Button: MDI Compass Rose #}
    <svg
      class="icon-menu"
      viewBox="0 0 24 24"
      width="32" height="32"
      aria-hidden="true"
      xmlns="http://www.w3.org/2000/svg">
      <path d="
        M15 9L12 0L9 9L0 12L9 15L12 24L15 15L24 12L15 9M4 12L10 10L11 12H4M12
		    20L10 14L12 13V20M12 4L14 10L12 11V4M14 14L13 12H20L14 14M8.7 17.3L5
		    19L6.7 15.3L8.3 15.8L8.7 17.3M17.3 15.3L19 19L15.3 17.3L15.8 15.7L17.3
		    15.3M6.7 8.7L5 5L8.7 6.7L8.2 8.2L6.7 8.7M15.3 6.7L19 5L17.3 8.7L15.7
		    8.2L15.3 6.7Z
      "/>
    </svg>

    {# Navigation Sidebar Close Button: MDI Page First #}
    <svg
      class="icon-close"
      viewBox="0 0 24 24"
      width="32" height="32"
      aria-hidden="true">
      <path d="
        M18.41,16.59L13.82,12L18.41,7.41L17,6L11,12L17,18L18.41,16.59M6,
        6H8V18H6V6Z
      "/>
      </svg>
  </button>

  {# Navigation Sidebar Backdrop #}
  <div id="sidebar-backdrop" aria-hidden="true"></div>
  <nav id="sidebar" aria-label="Site Navigation">
    <h2 style="margin-top: 0; margin-bottom: 1rem;">Navigation</h2>
    <ul>
      <li><a href="{{ '/' | url }}">Home</a></li>
      <li>
        <a href="{{ '/md/characters/' | url }}">Characters</a>
        <ul>
          <li><a href="{{ '/md/characters/#species' | url }}">Species</a></li>
      </ul>
      </li>
      <li>
        <a href="{{ '/md/magic/' | url }}">Magic</a>
        <ul>
          <li><a href="{{ '/md/magic/#the-six-colleges' | url }}">The Six Colleges</a></li>
          <li><a href="{{ '/md/magic/#arcane-backgrounds' | url }}">Arcane Backgrounds</a></li>
        </ul>
      </li>
      <!-- add more pages here as you create them -->
    </ul>
  </nav>

  {{ content | safe }}

  {# Navigation Sidebar Script #}
  <script src="{{ '/js/sidebar.js' | url }}"></script>
</body>
</html>